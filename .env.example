# Copy this file to .env and fill in your keys.
# .env is git-ignored — never commit real keys.

# Local frontend (Vite) proxies API calls to the Flask app. Default backend URL
# is http://127.0.0.1:8000 — same as `python app.py` when PORT is unset.
# VITE_DEV_BACKEND=http://127.0.0.1:8000

# ---------------------------------------------------------------------------
# LLM provider strategy
#
# Two providers, two phases of the project:
#   - OpenRouter is for PROTOTYPING (default during dev): cheap, fast,
#     swap models freely, low stakes per call.
#   - Anthropic direct is for PRODUCTION (demo, quality-sensitive runs):
#     higher quality, prompt caching, no gateway markup.
#
# Switch by setting LLM_PROVIDER below. Stages don't care which one is
# active — the runtime LLM client abstracts the wire-format differences.
# ---------------------------------------------------------------------------
LLM_PROVIDER=openrouter   # 'openrouter' for dev, 'anthropic' for production

# ---------------------------------------------------------------------------
# Anthropic — direct Claude API. PRODUCTION provider.
# Used for: demo runs, quality-sensitive synthesis (Stages 2 / 7 / 8 in
# particular). Supports Anthropic prompt caching, which is meaningful
# when the same retrieved-protocol context shows up across stages.
# Get a key at: https://console.anthropic.com/
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=
# Default to Haiku for lightweight stage work (lit review classification etc).
# Bump to claude-sonnet-4-6 or claude-opus-4-7 for quality-sensitive synthesis.
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ---------------------------------------------------------------------------
# OpenRouter — gateway. PROTOTYPING provider.
# Used for: day-to-day dev iteration. Cheap (~$0.30 per 1M output tokens
# on Gemini 2.5 Flash), fast, supports model A/B testing in one SDK.
# Hackathon code: use referral link COMM-HACKNATION-HAKT.
# Get a key at: https://openrouter.ai/keys (requires $5 minimum deposit)
# ---------------------------------------------------------------------------
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash

# ---------------------------------------------------------------------------
# Europe PMC — biomedical literature search for Stage 1 lit review.
# Free, no auth required, no signup. Returns structured authors, year,
# journal, plain-text abstract, DOI/PMID/PMCID — eliminating LLM
# hallucination of bibliographic data. ~40M+ biomedical papers.
# Docs: https://europepmc.org/RestfulWebService
# (No env var needed; this comment is here so teammates know which API
#  Stage 1 hits.)
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# Tavily — AI-optimized web search + content extraction.
#
# Used for Stage 3 materials enrichment (the PRIMARY path, not just gap-fill):
#   - Every reagent / equipment row goes through `search_for_supplier`
#     scoped to ~7 supplier domains (Sigma, Thermo, Promega, Qiagen, IDT,
#     ATCC, Addgene). The LLM extracts {supplier, catalog, price,
#     source_url}; only entries citing a real URL are kept ("verified" tier).
#   - Items with no Tavily match fall back to an LLM best-guess from
#     training data ("estimate" tier — no source_url, FE renders a
#     BEST-GUESS chip instead of a Source link).
#   - When supplier+catalog are known but price came back null, a second
#     `search_for_pricing` call fetches the full raw page content +
#     regex-or-LLM extracts the price.
#
# Stage 1 used to use Tavily but moved to Europe PMC (above) for
# structured biomedical metadata.
#
# Hackathon code: TVLY-HF9ETJRW
# Get a key at: https://app.tavily.com/
# ---------------------------------------------------------------------------
TAVILY_API_KEY=

# ---------------------------------------------------------------------------
# protocols.io — public protocol library (search + steps + materials).
# Used for: Stage 2 protocol retrieval, Stage 3 materials extraction.
# All v3/v4 read endpoints require Authorization: Bearer <token>, even
# for public protocols. Generate a personal access token at:
#   https://www.protocols.io  →  Settings  →  Developer applications
# ---------------------------------------------------------------------------
PROTOCOLS_IO_TOKEN=
