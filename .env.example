# Copy this file to .env and fill in your keys.
# .env is git-ignored — never commit real keys.

# ---------------------------------------------------------------------------
# Anthropic — direct Claude API access
# Used for: production-quality runs with Sonnet 4.6 / Opus 4.7 if/when we
# want to compare output quality against the lightweight default below.
# Get a key at: https://console.anthropic.com/
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=

# ---------------------------------------------------------------------------
# OpenRouter — single LLM gateway for ALL runtime calls.
# Used for: testing with lightweight models during dev (Gemini 2.5 Flash by
# default; can swap to free Llama / cheap Sonnet via the model env var below).
# Keeps infra surface small — one key, one SDK, swap models freely.
# Get a key at: https://openrouter.ai/keys (requires $5 minimum deposit)
# ---------------------------------------------------------------------------
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash

# ---------------------------------------------------------------------------
# Tavily — AI-optimized web search + content extraction.
# Used for: Stage 1 lit QC (novelty check), Stage 3 catalog # gap-fill
# (when protocols.io materials are vague), Stage 4 supplier-page price
# scraping (Thermo / Sigma / Promega / Qiagen / IDT / ATCC / Addgene).
# Hackathon code: TVLY-HF9ETJRW
# Get a key at: https://app.tavily.com/
# ---------------------------------------------------------------------------
TAVILY_API_KEY=
