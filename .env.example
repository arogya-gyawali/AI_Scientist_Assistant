# =============================================================================
# AI Scientist Assistant — environment template
# Copy to `.env` in the repo root and fill in values. Never commit real keys.
# =============================================================================

# -----------------------------------------------------------------------------
# 1) LLM — required for almost everything (lit review, protocol agents, chat…)
# -----------------------------------------------------------------------------
# Choose ONE strategy:
#   openrouter  → set OPENROUTER_API_KEY (typical local dev)
#   anthropic   → set ANTHROPIC_API_KEY
#   hybrid      → OpenRouter for reasoning + local Ollama for light tasks;
#                 needs OPENROUTER_API_KEY + Ollama running; see §4 below.

LLM_PROVIDER=openrouter

# OpenRouter (when LLM_PROVIDER=openrouter OR hybrid)
OPENROUTER_API_KEY=sk-or-whatever-your-key-is
OPENROUTER_MODEL=google/gemini-2.5-flash

# Anthropic (when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# -----------------------------------------------------------------------------
# 2) External APIs — required for “full product” behavior (strongly recommended)
# -----------------------------------------------------------------------------
# protocols.io — live protocol search & steps (Stage 2). Token required for API.
# Create: https://www.protocols.io → Settings → Developer applications (client access token).
# Paste the raw token only (no "Bearer " prefix, no quotes). Alias: PROTOCOLS_IO_ACCESS_TOKEN.
PROTOCOLS_IO_TOKEN=
# PROTOCOLS_IO_ACCESS_TOKEN=

# Tavily — supplier / price enrichment for materials (Stage 3 enrichment path).
# Without it, enrichment calls that expect Tavily may fail or degrade.
# Create: https://app.tavily.com/
TAVILY_API_KEY=

# -----------------------------------------------------------------------------
# 3) Optional tuning & runtime
# -----------------------------------------------------------------------------
# Flask (`python app.py`): default port 8000
# PORT=8000
# FLASK_DEBUG=0

# Verbose LLM routing logs (stdout); see src/clients/llm.py
# LLM_DEBUG=false

# Frontend dev proxy → backend (Vite). Default matches `python app.py`.
# VITE_DEV_BACKEND=http://127.0.0.1:8000

# -----------------------------------------------------------------------------
# 4) Hybrid + Ollama — only when LLM_PROVIDER=hybrid
# -----------------------------------------------------------------------------
# Install Ollama (https://ollama.com), then:
#   ollama pull llama3          # or match OLLAMA_MODEL below
#   ollama serve                # usually automatic as a service on macOS
# Hybrid sends task=extraction JSON paths (e.g. materials enrichment) locally;
# reasoning/architect/writer/etc. still use OpenRouter unless you add more task= wiring.
OLLAMA_MODEL=llama3
# OLLAMA_API_URL=http://localhost:11434/api/generate
# OLLAMA_TIMEOUT_S=120

# -----------------------------------------------------------------------------
# 5) No key needed
# -----------------------------------------------------------------------------
# Stage 1 literature uses Europe PMC (free, no env var).
