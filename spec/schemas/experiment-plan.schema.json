{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/aliiarustamova/AI_Scientist_Assistant/spec/schemas/experiment-plan.schema.json",
  "title": "ExperimentPlan",
  "description": "Shared blackboard document. Every stage reads and writes named fields here. Stage outputs are optional - populated as stages complete.",
  "type": "object",
  "required": ["id", "hypothesis", "status", "created_at", "updated_at", "meta"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string" },
    "hypothesis": { "$ref": "#/definitions/Hypothesis" },
    "lit_review": { "$ref": "#/definitions/LitReviewSession" },
    "protocol": { "$ref": "#/definitions/ProtocolGenerationOutput" },
    "materials": { "$ref": "#/definitions/MaterialsOutput" },
    "budget": { "$ref": "#/definitions/BudgetOutput" },
    "timeline": { "$ref": "#/definitions/TimelineOutput" },
    "validation": { "$ref": "#/definitions/ValidationOutput" },
    "critique": { "$ref": "#/definitions/DesignCritique" },
    "summary": { "$ref": "#/definitions/SummaryOutput" },
    "status": {
      "type": "object",
      "required": ["lit_review", "protocol", "materials", "budget", "timeline", "validation", "critique", "summary"],
      "additionalProperties": false,
      "properties": {
        "lit_review": { "$ref": "#/definitions/StageStatus" },
        "protocol":   { "$ref": "#/definitions/StageStatus" },
        "materials":  { "$ref": "#/definitions/StageStatus" },
        "budget":     { "$ref": "#/definitions/StageStatus" },
        "timeline":   { "$ref": "#/definitions/StageStatus" },
        "validation": { "$ref": "#/definitions/StageStatus" },
        "critique":   { "$ref": "#/definitions/StageStatus" },
        "summary":    { "$ref": "#/definitions/StageStatus" }
      }
    },
    "created_at": { "$ref": "#/definitions/ISO8601" },
    "updated_at": { "$ref": "#/definitions/ISO8601" },
    "meta": { "$ref": "#/definitions/ExperimentPlanMeta" }
  },

  "definitions": {

    "ISO8601": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 datetime string, e.g. '2026-04-25T14:30:00Z'"
    },

    "Duration": {
      "type": "string",
      "pattern": "^P(?!$)(\\d+Y)?(\\d+M)?(\\d+W)?(\\d+D)?(T(?=\\d)(\\d+H)?(\\d+M)?(\\d+(\\.\\d+)?S)?)?$",
      "description": "ISO 8601 duration string, e.g. 'PT2H30M', 'P3D', 'P2W'"
    },

    "Quantity": {
      "type": "object",
      "required": ["value", "unit"],
      "additionalProperties": false,
      "description": "Numeric value + unit. Stage 2 step parameters: volume, temperature, concentration, speed.",
      "properties": {
        "value": { "type": "number" },
        "unit": { "type": "string", "description": "'mL' | 'uL' | 'C' | 'rpm' | 'g' | 'M' | 'mM' | 'ng/uL' | ..." }
      }
    },

    "DOI": {
      "type": "string",
      "description": "Digital Object Identifier, e.g. '10.17504/protocols.io.baaciaaw'"
    },

    "URL": {
      "type": "string",
      "format": "uri"
    },

    "Money": {
      "type": "object",
      "required": ["amount", "currency"],
      "additionalProperties": false,
      "properties": {
        "amount": { "type": "number" },
        "currency": {
          "type": "string",
          "description": "ISO 4217 currency code, e.g. 'USD', 'EUR', 'JPY', 'CHF'"
        }
      }
    },

    "Citation": {
      "type": "object",
      "required": ["source", "confidence"],
      "additionalProperties": false,
      "properties": {
        "source": {
          "type": "string",
          "description": "'protocols.io' | 'tavily' | 'paper' | 'vendor' | 'llm_estimate' | 'supplier_lookup' | other"
        },
        "confidence": { "type": "string", "enum": ["high", "medium", "low"] },
        "doi":   { "$ref": "#/definitions/DOI" },
        "url":   { "$ref": "#/definitions/URL" },
        "title": { "type": "string" },
        "authors": { "type": "array", "items": { "type": "string" } },
        "year":  { "type": "integer" },
        "venue": {
          "type": "string",
          "description": "Journal, preprint server, or other publication venue (e.g. 'Nature Reviews Microbiology')."
        },
        "snippet": { "type": "string" },
        "relevance_score": { "type": "number", "minimum": 0, "maximum": 1, "description": "0-1; UI may render as percentage." },
        "description": {
          "type": "string",
          "description": "Neutral, factual paper description (lit-review refs)."
        },
        "matched_on": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Concept tags surfaced as chips (e.g. 'E. coli', 'Glucose'). Lit-review refs."
        },
        "importance": {
          "type": "string",
          "description": "'Why this matched' — LLM brief on relevance to the user's hypothesis (lit-review refs)."
        }
      }
    },

    "Hypothesis": {
      "type": "object",
      "required": ["id", "text", "created_at"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "text": { "type": "string" },
        "domain": { "type": "string" },
        "intervention": { "type": "string" },
        "measurable_outcome": { "type": "string" },
        "control_implied": { "type": "string" },
        "created_at": { "$ref": "#/definitions/ISO8601" }
      }
    },

    "StageName": {
      "type": "string",
      "enum": ["lit_review", "protocol", "materials", "budget", "timeline", "validation", "critique", "summary"]
    },

    "StageStatus": {
      "oneOf": [
        {
          "type": "object",
          "required": ["state"],
          "additionalProperties": false,
          "properties": { "state": { "const": "not_started" } }
        },
        {
          "type": "object",
          "required": ["state", "started_at"],
          "additionalProperties": false,
          "properties": {
            "state": { "const": "running" },
            "started_at": { "$ref": "#/definitions/ISO8601" }
          }
        },
        {
          "type": "object",
          "required": ["state", "completed_at"],
          "additionalProperties": false,
          "properties": {
            "state": { "const": "complete" },
            "completed_at": { "$ref": "#/definitions/ISO8601" }
          }
        },
        {
          "type": "object",
          "required": ["state", "failed_at", "error"],
          "additionalProperties": false,
          "properties": {
            "state": { "const": "failed" },
            "failed_at": { "$ref": "#/definitions/ISO8601" },
            "error": { "type": "string" }
          }
        }
      ]
    },

    "LitReviewOutput": {
      "type": "object",
      "required": ["signal", "description", "references", "searched_at", "tavily_query", "summary"],
      "additionalProperties": false,
      "properties": {
        "signal": { "type": "string", "enum": ["novel", "similar_work_exists", "exact_match_found"] },
        "description": { "type": "string", "description": "2-3 sentence explanation of the novelty signal." },
        "references": { "type": "array", "items": { "$ref": "#/definitions/Citation" }, "maxItems": 3 },
        "searched_at": { "$ref": "#/definitions/ISO8601" },
        "tavily_query": { "type": "string" },
        "summary": {
          "type": "string",
          "description": "3-4 sentence holistic wrap-up for the researcher: novelty assessment + key literature takeaway + actionable next step. Hard sentence limit."
        }
      }
    },

    "LitReviewChatMessage": {
      "type": "object",
      "required": ["role", "content", "timestamp"],
      "additionalProperties": false,
      "properties": {
        "role": { "type": "string", "enum": ["user", "assistant"] },
        "content": { "type": "string" },
        "cited_refs": { "type": "array", "items": { "type": "integer", "minimum": 0 } },
        "timestamp": { "$ref": "#/definitions/ISO8601" }
      }
    },

    "LitReviewSession": {
      "type": "object",
      "required": ["id", "hypothesis_id", "initial_result", "chat_history", "cached_search_context", "user_decision"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "hypothesis_id": { "type": "string" },
        "initial_result": { "$ref": "#/definitions/LitReviewOutput" },
        "chat_history": { "type": "array", "items": { "$ref": "#/definitions/LitReviewChatMessage" } },
        "cached_search_context": { "type": "string" },
        "user_decision": { "type": "string", "enum": ["pending", "proceed", "refine", "abandon"] }
      }
    },

    "StepParams": {
      "type": "object",
      "additionalProperties": false,
      "description": "Structured parameters extracted from a step. All optional — not every step has every parameter.",
      "properties": {
        "volume": { "$ref": "#/definitions/Quantity" },
        "temperature": { "$ref": "#/definitions/Quantity" },
        "duration": { "$ref": "#/definitions/Duration" },
        "concentration": { "$ref": "#/definitions/Quantity" },
        "speed": { "$ref": "#/definitions/Quantity", "description": "rpm or g" },
        "other": {
          "type": "object",
          "description": "Escape hatch for params we haven't promoted to first-class fields (pH, voltage, gas mix, ...).",
          "additionalProperties": { "type": "string" }
        }
      }
    },

    "ReagentRecipe": {
      "type": "object",
      "required": ["name", "components"],
      "additionalProperties": false,
      "description": "Recipe for a custom buffer / mix the researcher must prepare. Only emitted for non-commercial reagents.",
      "properties": {
        "name": { "type": "string" },
        "components": { "type": "array", "items": { "type": "string" } },
        "notes": { "type": "string" }
      }
    },

    "ProtocolStep": {
      "type": "object",
      "required": ["n", "title", "body_md", "equipment_needed", "reagents_referenced", "params", "controls", "todo_for_researcher", "source_step_refs", "is_critical", "is_pause_point", "troubleshooting", "reagent_recipes"],
      "additionalProperties": false,
      "properties": {
        "n": { "type": "integer", "minimum": 1 },
        "title": { "type": "string" },
        "body_md": { "type": "string" },
        "duration": { "$ref": "#/definitions/Duration" },
        "equipment_needed": { "type": "array", "items": { "type": "string" } },
        "reagents_referenced": { "type": "array", "items": { "type": "string" } },
        "params": { "$ref": "#/definitions/StepParams" },
        "controls": { "type": "array", "items": { "type": "string" } },
        "todo_for_researcher": { "type": "array", "items": { "type": "string" }, "description": "Items the LLM flagged as needing a researcher decision before running." },
        "source_step_refs": { "type": "array", "items": { "type": "string" }, "description": "protocols.io step ids that informed this step (auditability)." },
        "notes": { "type": "string" },
        "cited_doi": { "$ref": "#/definitions/DOI" },
        "anticipated_outcome": { "type": "string", "description": "What to expect at the bench after this step." },
        "is_critical": { "type": "boolean", "description": "Steps where ~80% of failures happen; sparingly used." },
        "is_pause_point": { "type": "boolean", "description": "Safe stopping point — researcher can resume later." },
        "troubleshooting": { "type": "array", "items": { "type": "string" } },
        "reagent_recipes": { "type": "array", "items": { "$ref": "#/definitions/ReagentRecipe" } }
      }
    },

    "Deviation": {
      "type": "object",
      "required": ["from_source", "to_adapted", "reason", "source_protocol_id", "confidence"],
      "additionalProperties": false,
      "description": "An adaptation the LLM made from a source protocol. Required so researchers can audit every change rather than trusting blindly.",
      "properties": {
        "from_source": { "type": "string" },
        "to_adapted": { "type": "string" },
        "reason": { "type": "string" },
        "source_protocol_id": { "type": "string" },
        "confidence": { "type": "string", "enum": ["low", "medium", "high"] }
      }
    },

    "ProcedureSuccessCriterion": {
      "type": "object",
      "required": ["what", "how_measured", "pass_fail"],
      "additionalProperties": false,
      "description": "Per-procedure marker. Stage 6 (Validation) owns the experiment-wide SuccessCriterion (richer: statistical_test, expected_value).",
      "properties": {
        "what": { "type": "string" },
        "how_measured": { "type": "string" },
        "threshold": { "type": "string" },
        "pass_fail": { "type": "boolean" }
      }
    },

    "Procedure": {
      "type": "object",
      "required": ["name", "intent", "steps", "equipment", "reagents", "deviations_from_source", "source_protocol_ids", "success_criteria"],
      "additionalProperties": false,
      "description": "A logical group of steps. Each procedure is the unit a single procedure-writer agent owns — context isolation by construction.",
      "properties": {
        "name": { "type": "string" },
        "intent": { "type": "string" },
        "steps": { "type": "array", "items": { "$ref": "#/definitions/ProtocolStep" } },
        "equipment": { "type": "array", "items": { "type": "string" } },
        "reagents": { "type": "array", "items": { "type": "string" } },
        "deviations_from_source": { "type": "array", "items": { "$ref": "#/definitions/Deviation" } },
        "source_protocol_ids": { "type": "array", "items": { "type": "string" } },
        "success_criteria": { "type": "array", "items": { "$ref": "#/definitions/ProcedureSuccessCriterion" } },
        "total_duration": { "$ref": "#/definitions/Duration", "description": "ISO 8601 sum of step durations (deterministic, computed by orchestrator)." }
      }
    },

    "CitedProtocol": {
      "type": "object",
      "required": ["title", "contribution_weight"],
      "additionalProperties": false,
      "properties": {
        "doi": { "$ref": "#/definitions/DOI" },
        "protocols_io_id": { "type": "string" },
        "title": { "type": "string" },
        "contribution_weight": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },

    "RegulatoryRequirement": {
      "type": "object",
      "required": ["requirement", "authority", "applicable_because"],
      "additionalProperties": false,
      "properties": {
        "requirement": { "type": "string", "description": "e.g. 'IACUC approval', 'IRB approval', 'BSL-2 facility', 'IBC review', 'EHS sign-off'" },
        "authority": { "type": "string", "description": "e.g. 'institutional', 'FDA', 'NIH', 'OSHA', 'EPA'" },
        "applicable_because": { "type": "string" },
        "estimated_lead_time": { "$ref": "#/definitions/Duration" },
        "notes": { "type": "string" }
      }
    },

    "ProtocolGenerationOutput": {
      "type": "object",
      "required": ["experiment_type", "procedures", "steps", "cited_protocols", "regulatory_requirements", "assumptions", "total_steps", "source_protocol_ids", "generated_at"],
      "additionalProperties": false,
      "properties": {
        "experiment_type": { "type": "string" },
        "domain": { "type": "string" },
        "procedures": { "type": "array", "items": { "$ref": "#/definitions/Procedure" } },
        "steps": { "type": "array", "items": { "$ref": "#/definitions/ProtocolStep" }, "description": "Flat re-numbered view derived from procedures, for FE checklist rendering." },
        "cited_protocols": { "type": "array", "items": { "$ref": "#/definitions/CitedProtocol" } },
        "regulatory_requirements": { "type": "array", "items": { "$ref": "#/definitions/RegulatoryRequirement" } },
        "assumptions": { "type": "array", "items": { "type": "string" } },
        "total_steps": { "type": "integer", "minimum": 0 },
        "source_protocol_ids": { "type": "array", "items": { "type": "string" } },
        "generated_at": { "$ref": "#/definitions/ISO8601" },
        "total_duration": { "$ref": "#/definitions/Duration", "description": "ISO 8601 sum across all procedures." }
      }
    },

    "Material": {
      "type": "object",
      "required": ["id", "name", "category"],
      "additionalProperties": false,
      "description": "vendor/sku left empty until Stage 4 (Budget) backfills them. spec/purpose populated for equipment items only.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string", "enum": ["reagent", "consumable", "equipment", "cell_line", "organism"] },
        "qty": { "type": "number" },
        "unit": { "type": "string" },
        "spec": { "type": "string", "description": "Equipment only, e.g. 'benchtop centrifuge, >=3000g, refrigerated'." },
        "purpose": { "type": "string", "description": "Equipment only, e.g. 'cell pelleting'." },
        "vendor": { "type": "string", "description": "Backfilled by Stage 4." },
        "sku": { "type": "string", "description": "Backfilled by Stage 4." },
        "storage": { "type": "string" },
        "hazard": { "type": "string" },
        "alternatives": { "type": "array", "items": { "type": "string" } }
      }
    },

    "MaterialsOutput": {
      "type": "object",
      "required": ["materials", "total_unique_items", "by_category", "gaps", "generated_at"],
      "additionalProperties": false,
      "properties": {
        "materials": { "type": "array", "items": { "$ref": "#/definitions/Material" } },
        "total_unique_items": { "type": "integer", "minimum": 0 },
        "by_category": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "gaps": { "type": "array", "items": { "type": "string" } },
        "generated_at": { "$ref": "#/definitions/ISO8601" }
      }
    },

    "SupplierQuote": {
      "type": "object",
      "required": ["vendor", "product_name", "catalog_number", "price", "url", "scraped_at", "source_via"],
      "additionalProperties": false,
      "properties": {
        "vendor": { "type": "string" },
        "product_name": { "type": "string" },
        "catalog_number": { "type": "string" },
        "pack_size": { "type": "string" },
        "price": { "$ref": "#/definitions/Money" },
        "url": { "$ref": "#/definitions/URL" },
        "in_stock": { "type": "boolean" },
        "scraped_at": { "$ref": "#/definitions/ISO8601" },
        "source_via": { "type": "string", "enum": ["tavily", "direct_api", "manual"] }
      }
    },

    "BudgetLineItem": {
      "type": "object",
      "required": ["material_id", "material_name", "qty", "unit_cost", "total", "source", "confidence"],
      "additionalProperties": false,
      "properties": {
        "material_id": { "type": "string" },
        "material_name": { "type": "string" },
        "qty": { "type": "number" },
        "unit_cost": { "$ref": "#/definitions/Money" },
        "total": { "$ref": "#/definitions/Money" },
        "source": { "type": "string", "enum": ["protocols_io_listed", "supplier_lookup", "llm_estimate", "recent_quote"] },
        "confidence": { "type": "string", "enum": ["high", "medium", "low"] },
        "notes": { "type": "string" },
        "supplier_quotes": { "type": "array", "items": { "$ref": "#/definitions/SupplierQuote" } },
        "selected_quote": { "$ref": "#/definitions/SupplierQuote" }
      }
    },

    "BudgetOutput": {
      "type": "object",
      "required": ["line_items", "subtotals_by_category", "total", "contingency_pct", "total_with_contingency", "disclaimer", "assumptions"],
      "additionalProperties": false,
      "properties": {
        "line_items": { "type": "array", "items": { "$ref": "#/definitions/BudgetLineItem" } },
        "subtotals_by_category": {
          "type": "object",
          "additionalProperties": { "$ref": "#/definitions/Money" }
        },
        "total": { "$ref": "#/definitions/Money" },
        "contingency_pct": { "type": "number", "minimum": 0 },
        "total_with_contingency": { "$ref": "#/definitions/Money" },
        "disclaimer": { "type": "string" },
        "assumptions": { "type": "array", "items": { "type": "string" } },
        "preferred_suppliers": { "type": "array", "items": { "type": "string" } }
      }
    },

    "TimelineTask": {
      "type": "object",
      "required": ["step_n", "name", "duration", "can_parallel"],
      "additionalProperties": false,
      "properties": {
        "step_n": { "type": "integer", "minimum": 1 },
        "name": { "type": "string" },
        "duration": { "$ref": "#/definitions/Duration" },
        "hands_on_time": { "$ref": "#/definitions/Duration" },
        "can_parallel": { "type": "boolean" }
      }
    },

    "TimelinePhase": {
      "type": "object",
      "required": ["id", "name", "duration", "tasks", "depends_on"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "duration": { "$ref": "#/definitions/Duration" },
        "tasks": { "type": "array", "items": { "$ref": "#/definitions/TimelineTask" } },
        "depends_on": { "type": "array", "items": { "type": "string" } },
        "parallel_with": { "type": "array", "items": { "type": "string" } }
      }
    },

    "TimelineOutput": {
      "type": "object",
      "required": ["phases", "total_duration", "critical_path", "assumptions"],
      "additionalProperties": false,
      "properties": {
        "phases": { "type": "array", "items": { "$ref": "#/definitions/TimelinePhase" } },
        "total_duration": { "$ref": "#/definitions/Duration" },
        "critical_path": { "type": "array", "items": { "type": "string" } },
        "assumptions": { "type": "array", "items": { "type": "string" } },
        "earliest_completion_date": { "$ref": "#/definitions/ISO8601" }
      }
    },

    "SuccessCriterion": {
      "type": "object",
      "required": ["id", "criterion", "measurement_method", "threshold"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "criterion": { "type": "string" },
        "measurement_method": { "type": "string" },
        "threshold": { "type": "string" },
        "statistical_test": { "type": "string" },
        "expected_value": { "type": "string" }
      }
    },

    "FailureMode": {
      "type": "object",
      "required": ["mode", "likely_cause", "mitigation"],
      "additionalProperties": false,
      "properties": {
        "mode": { "type": "string" },
        "likely_cause": { "type": "string" },
        "mitigation": { "type": "string" }
      }
    },

    "Control": {
      "type": "object",
      "required": ["name", "type", "purpose"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["positive", "negative", "vehicle", "sham"] },
        "purpose": { "type": "string" }
      }
    },

    "EffectSize": {
      "type": "object",
      "required": ["value", "type"],
      "additionalProperties": false,
      "properties": {
        "value": { "type": "number" },
        "type": { "type": "string", "description": "'cohens_d' | 'percent_change' | 'fold_change' | 'odds_ratio' | other" }
      }
    },

    "PowerCalculation": {
      "type": "object",
      "required": ["statistical_test", "alpha", "power", "effect_size", "n_per_group", "groups", "total_n", "assumptions", "rationale"],
      "additionalProperties": false,
      "properties": {
        "statistical_test": { "type": "string" },
        "alpha": { "type": "number", "minimum": 0, "maximum": 1 },
        "power": { "type": "number", "minimum": 0, "maximum": 1 },
        "effect_size": { "$ref": "#/definitions/EffectSize" },
        "n_per_group": { "type": "integer", "minimum": 1 },
        "groups": { "type": "integer", "minimum": 1 },
        "total_n": { "type": "integer", "minimum": 1 },
        "assumptions": { "type": "array", "items": { "type": "string" } },
        "rationale": { "type": "string" }
      }
    },

    "ValidationOutput": {
      "type": "object",
      "required": ["success_criteria", "controls", "failure_modes", "power_calculation", "expected_outcome_summary", "go_no_go_threshold"],
      "additionalProperties": false,
      "properties": {
        "success_criteria": { "type": "array", "items": { "$ref": "#/definitions/SuccessCriterion" } },
        "controls": { "type": "array", "items": { "$ref": "#/definitions/Control" } },
        "failure_modes": { "type": "array", "items": { "$ref": "#/definitions/FailureMode" } },
        "power_calculation": { "$ref": "#/definitions/PowerCalculation" },
        "expected_outcome_summary": { "type": "string" },
        "go_no_go_threshold": { "type": "string" }
      }
    },

    "DesignConcern": {
      "type": "object",
      "required": ["id", "category", "severity", "description", "suggestion"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "category": { "type": "string", "description": "'controls' | 'confounders' | 'sample_size' | 'alternative_hypotheses' | 'reproducibility' | 'feasibility' | 'ethics' | 'measurement' | 'novelty' | 'statistical_validity' | other" },
        "severity": { "type": "string", "enum": ["high", "medium", "low"] },
        "description": { "type": "string" },
        "suggestion": { "type": "string" },
        "cited_step": { "type": "integer", "minimum": 1 }
      }
    },

    "DesignCritique": {
      "type": "object",
      "required": ["overall_soundness", "concerns", "missing_controls", "missing_considerations", "strengths", "reviewer_perspective", "reviewed_at"],
      "additionalProperties": false,
      "properties": {
        "overall_soundness": { "type": "string", "enum": ["strong", "acceptable", "concerns", "major_issues"] },
        "concerns": { "type": "array", "items": { "$ref": "#/definitions/DesignConcern" } },
        "missing_controls": { "type": "array", "items": { "type": "string" } },
        "missing_considerations": { "type": "array", "items": { "type": "string" } },
        "strengths": { "type": "array", "items": { "type": "string" } },
        "reviewer_perspective": { "type": "string" },
        "reviewed_at": { "$ref": "#/definitions/ISO8601" }
      }
    },

    "RiskAssessment": {
      "type": "object",
      "required": ["risk", "likelihood", "impact"],
      "additionalProperties": false,
      "properties": {
        "risk": { "type": "string" },
        "likelihood": { "type": "string", "enum": ["low", "medium", "high"] },
        "impact": { "type": "string", "enum": ["low", "medium", "high"] }
      }
    },

    "SummaryOutput": {
      "type": "object",
      "required": ["tldr", "key_decisions", "risk_assessment", "novelty_position"],
      "additionalProperties": false,
      "properties": {
        "tldr": { "type": "string" },
        "key_decisions": { "type": "array", "items": { "type": "string" } },
        "risk_assessment": { "type": "array", "items": { "$ref": "#/definitions/RiskAssessment" } },
        "novelty_position": { "type": "string" }
      }
    },

    "ExperimentPlanMeta": {
      "type": "object",
      "required": ["generated_at", "model_id", "pipeline_version", "feedback_applied"],
      "additionalProperties": false,
      "properties": {
        "generated_at": { "$ref": "#/definitions/ISO8601" },
        "model_id": { "type": "string" },
        "pipeline_version": { "type": "string" },
        "feedback_applied": { "type": "boolean" },
        "feedback_session_ids": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
